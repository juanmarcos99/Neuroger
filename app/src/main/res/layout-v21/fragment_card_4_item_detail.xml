<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    style="@style/CardStyle"
    android:layout_width="match_parent"
    android:layout_height="@dimen/card_4_item_height"
    android:background="@android:color/white"
    android:elevation="3dp">

    <include
        android:id="@id/card_image"
        layout="@layout/card_image"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentLeft="true"
        android:layout_alignParentStart="true"
        android:layout_centerVertical="true"
        android:layout_marginLeft="@dimen/card_image_margin"
        android:layout_marginRight="@dimen/card_image_margin" />

    <include
        android:id="@id/card_image_arrow"
        layout="@layout/card_image_arrow"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentEnd="true"
        android:layout_alignParentRight="true"
        android:layout_centerVertical="true"
        android:layout_marginLeft="@dimen/card_image_margin"
        android:layout_marginRight="@dimen/card_image_margin" />

    <TableLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_centerVertical="true"
        android:layout_toEndOf="@id/card_image_arrow"
        android:layout_toLeftOf="@id/card_image_arrow"
        android:layout_toRightOf="@id/card_image"
        android:layout_toStartOf="@id/card_image"
        android:stretchColumns="0,1">

        <TableRow
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <software.cneuro.neurogertheme.TextViewFont
                android:id="@+id/card_item_title"
                style="@style/SubjectCardTitleBlackTextStyle"
                android:layout_span="2"
                android:text="@string/list_item_text"
                app:myFont="Roboto-Light_3.ttf" />
        </TableRow>

        <TableRow
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <software.cneuro.neurogertheme.TextViewFont
                android:id="@+id/card_1_item_text"
                style="@style/SubjectCardDetailTextStyle"
                android:layout_marginEnd="8dp"
                android:layout_marginRight="8dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="@string/list_item_sub_text"
                app:myFont="Roboto-Thin_3.ttf" />

            <software.cneuro.neurogertheme.TextViewFont
                android:id="@+id/card_2_item_text"
                style="@style/SubjectCardDetailTextStyle"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="@string/list_item_sub_text"
                app:myFont="Roboto-Thin_3.ttf" />
        </TableRow>

        <TableRow
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <software.cneuro.neurogertheme.TextViewFont
                android:id="@+id/card_3_item_text"
                style="@style/SubjectCardDetailTextStyle"
                android:layout_marginEnd="8dp"
                android:layout_marginRight="8dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="@string/list_item_sub_text"
                app:myFont="Roboto-Thin_3.ttf" />

            <software.cneuro.neurogertheme.TextViewFont
                android:id="@+id/card_4_item_text"
                style="@style/SubjectCardDetailTextStyle"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="@string/list_item_sub_text"
                app:myFont="Roboto-Thin_3.ttf" />
        </TableRow>
    </TableLayout>

</RelativeLayout>