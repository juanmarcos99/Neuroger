<?xml version="1.0" encoding="utf-8"?>
<androidx.constraint.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    style="@style/CardStyle"
    android:layout_width="match_parent"
    android:layout_height="@dimen/card_4_item_height"
    tools:layout_editor_absoluteX="0dp"
    tools:layout_editor_absoluteY="89dp">

    <include
        android:id="@id/card_image"
        layout="@layout/card_image"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="8dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.5" />

    <software.cneuro.neurogertheme.TextViewFont
        android:id="@+id/card_1_item_text"
        style="@style/SubjectCardDetailTextStyle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginLeft="8dp"
        android:ellipsize="end"
        android:maxLines="1"
        android:text="@string/list_item_sub_text"
        app:layout_constraintBottom_toBottomOf="@+id/card_image"
        app:layout_constraintHorizontal_weight="1"
        app:layout_constraintLeft_toRightOf="@+id/card_image"
        app:layout_constraintRight_toLeftOf="@+id/card_2_item_text"
        app:layout_constraintTop_toTopOf="@+id/card_image"
        app:layout_constraintVertical_bias="0.535"
        app:myFont="Roboto-Light_3.ttf" />

    <include
        android:id="@id/card_image_arrow"
        layout="@layout/card_image_arrow"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginRight="8dp"
        app:layout_constraintBottom_toBottomOf="@+id/card_2_item_text"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toTopOf="@+id/card_2_item_text" />

    <software.cneuro.neurogertheme.TextViewFont
        android:id="@+id/card_item_title"
        style="@style/SubjectCardTitleBlackTextStyle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:layout_marginLeft="8dp"
        android:layout_marginEnd="8dp"
        android:layout_marginRight="8dp"
        android:ellipsize="end"
        android:maxLines="1"
        android:text="@string/list_item_text"
        app:layout_constraintBottom_toTopOf="@+id/card_1_item_text"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintLeft_toRightOf="@+id/card_image"
        app:layout_constraintRight_toLeftOf="@+id/card_image_arrow"
        app:myFont="Roboto-Light_3.ttf" />

    <software.cneuro.neurogertheme.TextViewFont
        android:id="@+id/card_3_item_text"
        style="@style/SubjectCardDetailTextStyle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="0dp"
        android:layout_marginEnd="8dp"
        android:layout_marginRight="0dp"
        android:ellipsize="end"
        android:maxLines="1"
        android:text="@string/list_item_sub_text"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintLeft_toLeftOf="@+id/card_1_item_text"
        app:layout_constraintRight_toRightOf="@+id/card_1_item_text"
        app:layout_constraintTop_toBottomOf="@+id/card_1_item_text"
        app:myFont="Roboto-Light_3.ttf" />

    <software.cneuro.neurogertheme.TextViewFont
        android:id="@+id/card_2_item_text"
        style="@style/SubjectCardDetailTextStyle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginRight="8dp"
        android:ellipsize="end"
        android:maxLines="1"
        android:text="@string/list_item_sub_text"
        app:layout_constraintBottom_toBottomOf="@+id/card_1_item_text"
        app:layout_constraintHorizontal_weight="1"
        app:layout_constraintLeft_toRightOf="@+id/card_1_item_text"
        app:layout_constraintRight_toLeftOf="@+id/card_image_arrow"
        app:layout_constraintTop_toTopOf="@+id/card_1_item_text"
        app:layout_constraintVertical_bias="0.0"
        app:myFont="Roboto-Light_3.ttf" />

    <software.cneuro.neurogertheme.TextViewFont
        android:id="@+id/card_4_item_text"
        style="@style/SubjectCardDetailTextStyle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:ellipsize="end"
        android:maxLines="1"
        android:text="@string/list_item_sub_text"
        app:layout_constraintBottom_toBottomOf="@+id/card_3_item_text"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintLeft_toLeftOf="@+id/card_2_item_text"
        app:layout_constraintRight_toRightOf="@+id/card_2_item_text"
        app:layout_constraintTop_toTopOf="@+id/card_3_item_text"
        app:myFont="Roboto-Light_3.ttf" />
</androidx.constraint.ConstraintLayout>