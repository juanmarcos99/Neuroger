<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <software.cneuro.neurogertheme.EditTextFont
        android:id="@+id/card_input_edittext"
        style="@style/EditTextStyle"
        android:layout_width="@dimen/edittext_mini_mental_width"
        android:layout_height="@dimen/edittext_height"
        android:layout_alignParentEnd="true"
        android:layout_alignParentRight="true"
        android:layout_centerVertical="true"
        android:layout_marginEnd="8dp"
        android:layout_marginRight="8dp"
        android:hint="@string/edittext_math_hint"
        android:padding="8dp"
        app:myFont="Roboto-Light_3.ttf" />

    <software.cneuro.neurogertheme.CheckBoxFont
        android:id="@+id/card_input_cbx"
        style="@style/CheckboxStyle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentLeft="true"
        android:layout_alignParentStart="true"
        android:layout_marginEnd="@dimen/rdb_input_margin_right"
        android:layout_marginRight="@dimen/rdb_input_margin_right"
        android:layout_toLeftOf="@id/card_input_edittext"
        android:layout_toStartOf="@id/card_input_edittext"
        android:text="@string/cbx_1"
        app:myFont="Roboto-Light_3.ttf" />

</RelativeLayout>