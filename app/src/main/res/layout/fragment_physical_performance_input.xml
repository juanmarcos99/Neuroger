                            android:layout_marginEnd="16dp"
                            android:layout_marginLeft="16dp"
                            android:layout_marginRight="16dp"
                            android:layout_marginStart="16dp"
                            android:layout_span="2"
                            android:hint="@string/edittext_measure_hint"
                            android:inputType="numberDecimal"
                            android:padding="8dp"
                            app:myFont="Roboto-Light_3.ttf" />
                    </TableRow>

                    <TableRow
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:gravity="center_vertical">

                        <software.cneuro.neurogertheme.TextViewFont
                            style="@style/EvaluationCardDetailTextStyle"
                            android:text="@string/card_label_right_hand_2"
                            app:myFont="Roboto-Light_3.ttf" />

                        <software.cneuro.neurogertheme.EditTextFont
                            android:id="@+id/card_edit_grip_strength_right_hand_2"
                            style="@style/EditTextStyle"
                            android:layout_height="@dimen/edittext_height"
                            android:layout_marginEnd="16dp"
                            android:layout_marginLeft="16dp"
                            android:layout_marginRight="16dp"
                            android:layout_marginStart="16dp"
                            android:layout_span="2"
                            android:hint="@string/edittext_measure_hint"
                            android:inputType="numberDecimal"
                            android:padding="8dp"
                            app:myFont="Roboto-Light_3.ttf" />
                    </TableRow>

                    <TableRow
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:gravity="center_vertical">

                        <software.cneuro.neurogertheme.TextViewFont
                            style="@style/EvaluationCardDetailTextStyle"
                            android:text="@string/card_label_left_hand_2"
                            app:myFont="Roboto-Light_3.ttf" />

                        <software.cneuro.neurogertheme.EditTextFont
                            android:id="@+id/card_edit_grip_strength_left_hand_2"
                            style="@style/EditTextStyle"
                            android:layout_height="@dimen/edittext_height"
                            android:layout_marginEnd="16dp"
                            android:layout_marginLeft="16dp"
                            android:layout_marginRight="16dp"
                            android:layout_marginStart="16dp"
                            android:hint="@string/edittext_measure_hint"
                            android:inputType="numberDecimal"
                            android:padding="8dp"
                            app:myFont="Roboto-Light_3.ttf" />

                        <ImageButton
                            android:id="@+id/card_btn_calculate_right_hand_grip_strength"
                            style="@style/CalculateImageButtonStyle"
                            android:layout_width="@dimen/edittext_height"
                            android:layout_height="@dimen/edittext_height"
                            android:layout_marginEnd="8dp"
                            android:layout_marginRight="8dp"
                            android:contentDescription="@string/cd_list_item_icon" />
                    </TableRow>
                </TableLayout>

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:background="@color/physical_performance_result_background">

                    <ImageView
                        android:id="@+id/card_result_grip_strength_icon"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/card_evaluation_help_image_height"
                        android:layout_centerInParent="true"
                        android:contentDescription="@string/cd_list_item_icon"
