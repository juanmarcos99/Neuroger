<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:card_view="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <include
            layout="@layout/card_score_result"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/fragment_margin"
            android:layout_marginTop="@dimen/fragment_margin"
            android:layout_marginRight="@dimen/fragment_margin" />

        <androidx.v7.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginStart="@dimen/fragment_margin"
            android:layout_marginLeft="@dimen/fragment_margin"
            android:layout_marginTop="@dimen/fragment_margin"
            android:layout_marginEnd="@dimen/fragment_margin"
            android:layout_marginRight="@dimen/fragment_margin"
            card_view:cardBackgroundColor="@color/card_background"
            card_view:cardCornerRadius="@dimen/card_corner_radius"
            card_view:cardElevation="@dimen/card_elevation">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingBottom="@dimen/fragment_margin">

                <software.cneuro.neurogertheme.TextViewFont
                    style="@style/SubjectCardTitleWhiteTextStyle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@color/primary"
                    android:gravity="center_vertical"
                    android:padding="@dimen/fragment_margin"
                    android:text="@string/card_label_fatigue"
                    app:myFont="Roboto-Thin_3.ttf" />

                <software.cneuro.neurogertheme.TextViewFont
                    android:id="@+id/card_answer_fatigue"
                    style="@style/EvaluationCardDetailTextStyle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/fragment_margin"
                    android:paddingLeft="@dimen/fragment_margin"
                    android:paddingEnd="@dimen/fragment_margin"
                    android:paddingRight="@dimen/fragment_margin"
                    app:myFont="Roboto-Light_3.ttf"
                    tools:text="@string/label_answer" />

            </LinearLayout>
        </androidx.v7.widget.CardView>

        <androidx.v7.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginStart="@dimen/fragment_margin"
            android:layout_marginLeft="@dimen/fragment_margin"
            android:layout_marginTop="@dimen/fragment_margin"
            android:layout_marginEnd="@dimen/fragment_margin"
            android:layout_marginRight="@dimen/fragment_margin"
            card_view:cardBackgroundColor="@color/card_background"
            card_view:cardCornerRadius="@dimen/card_corner_radius"
            card_view:cardElevation="@dimen/card_elevation">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingBottom="@dimen/fragment_margin">

                <software.cneuro.neurogertheme.TextViewFont
                    style="@style/SubjectCardTitleWhiteTextStyle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@color/primary"
                    android:gravity="center_vertical"
                    android:padding="@dimen/fragment_margin"
                    android:text="@string/card_label_resistance"
                    app:myFont="Roboto-Thin_3.ttf" />

                <software.cneuro.neurogertheme.TextViewFont
                    android:id="@+id/card_answer_resistance"
                    style="@style/EvaluationCardDetailTextStyle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/fragment_margin"
                    android:paddingLeft="@dimen/fragment_margin"
                    android:paddingEnd="@dimen/fragment_margin"
                    android:paddingRight="@dimen/fragment_margin"
                    app:myFont="Roboto-Light_3.ttf"
                    tools:text="@string/label_answer" />

            </LinearLayout>
        </androidx.v7.widget.CardView>

        <androidx.v7.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginStart="@dimen/fragment_margin"
            android:layout_marginLeft="@dimen/fragment_margin"
            android:layout_marginTop="@dimen/fragment_margin"
            android:layout_marginEnd="@dimen/fragment_margin"
            android:layout_marginRight="@dimen/fragment_margin"
            card_view:cardBackgroundColor="@color/card_background"
            card_view:cardCornerRadius="@dimen/card_corner_radius"
            card_view:cardElevation="@dimen/card_elevation">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingBottom="@dimen/fragment_margin">

                <software.cneuro.neurogertheme.TextViewFont
                    style="@style/SubjectCardTitleWhiteTextStyle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@color/primary"
                    android:gravity="center_vertical"
                    android:padding="@dimen/fragment_margin"
                    android:text="@string/card_label_wandering"
                    app:myFont="Roboto-Thin_3.ttf" />

                <software.cneuro.neurogertheme.TextViewFont
                    android:id="@+id/card_answer_wandering"
                    style="@style/EvaluationCardDetailTextStyle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/fragment_margin"
                    android:paddingLeft="@dimen/fragment_margin"
                    android:paddingEnd="@dimen/fragment_margin"
                    android:paddingRight="@dimen/fragment_margin"
                    app:myFont="Roboto-Light_3.ttf"
                    tools:text="@string/label_answer" />

            </LinearLayout>
        </androidx.v7.widget.CardView>

        <androidx.v7.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginStart="@dimen/fragment_margin"
            android:layout_marginLeft="@dimen/fragment_margin"
            android:layout_marginTop="@dimen/fragment_margin"
            android:layout_marginEnd="@dimen/fragment_margin"
            android:layout_marginRight="@dimen/fragment_margin"
            card_view:cardBackgroundColor="@color/card_background"
            card_view:cardCornerRadius="@dimen/card_corner_radius"
            card_view:cardElevation="@dimen/card_elevation">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingBottom="@dimen/fragment_margin">

                <software.cneuro.neurogertheme.TextViewFont
                    style="@style/SubjectCardTitleWhiteTextStyle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@color/primary"
                    android:gravity="center_vertical"
                    android:padding="@dimen/fragment_margin"
                    android:text="@string/card_label_diseases"
                    app:myFont="Roboto-Thin_3.ttf" />

                <LinearLayout
                    android:id="@+id/card_answer_diseases_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />

            </LinearLayout>
        </androidx.v7.widget.CardView>

        <androidx.v7.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_margin="@dimen/fragment_margin"
            card_view:cardBackgroundColor="@color/card_background"
            card_view:cardCornerRadius="@dimen/card_corner_radius"
            card_view:cardElevation="@dimen/card_elevation">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingBottom="@dimen/fragment_margin">

                <software.cneuro.neurogertheme.TextViewFont
                    style="@style/SubjectCardTitleWhiteTextStyle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@color/primary"
                    android:gravity="center_vertical"
                    android:padding="@dimen/fragment_margin"
                    android:text="@string/card_label_weight_loss"
                    app:myFont="Roboto-Thin_3.ttf" />

                <software.cneuro.neurogertheme.TextViewFont
                    android:id="@+id/card_answer_weight_current"
                    style="@style/EvaluationCardDetailTextStyle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/fragment_margin"
                    android:paddingLeft="@dimen/fragment_margin"
                    android:paddingEnd="@dimen/fragment_margin"
                    android:paddingRight="@dimen/fragment_margin"
                    app:myFont="Roboto-Light_3.ttf"
                    tools:text="@string/label_answer" />

                <software.cneuro.neurogertheme.TextViewFont
                    android:id="@+id/card_answer_weight_year_ago"
                    style="@style/EvaluationCardDetailTextStyle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/fragment_margin"
                    android:paddingLeft="@dimen/fragment_margin"
                    android:paddingEnd="@dimen/fragment_margin"
                    android:paddingRight="@dimen/fragment_margin"
                    app:myFont="Roboto-Light_3.ttf"
                    tools:text="@string/label_answer" />

            </LinearLayout>
        </androidx.v7.widget.CardView>

    </LinearLayout>
</ScrollView>