<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <software.cneuro.neurogertheme.TextViewFont
        android:id="@+id/questionary_text"
        style="@style/QuestionnaireTextStyle"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@+id/radiogroup_questionary_answer"
        android:layout_alignParentTop="true"
        android:layout_marginLeft="@dimen/questionary_text_box_margin_left"
        android:layout_marginRight="@dimen/questionary_text_box_margin_left"
        android:background="@drawable/question_box"
        android:gravity="center"
        android:padding="16dp"
        android:text="@string/list_item_text"
        app:myFont="Roboto-Thin_3.ttf" />

    <RadioGroup
        android:id="@+id/radiogroup_questionary_answer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_marginStart="@dimen/questionary_answer_margin_left"
        android:layout_marginLeft="@dimen/questionary_answer_margin_left"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="@dimen/questionary_text_box_margin_left"
        android:layout_marginRight="@dimen/questionary_text_box_margin_left"
        android:background="@drawable/questionary_answer_box"
        android:paddingStart="12dp"
        android:paddingLeft="12dp"
        android:paddingTop="8dp"
        android:paddingEnd="8dp"
        android:paddingRight="8dp"
        android:paddingBottom="8dp" />

</RelativeLayout>