<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <androidx.v7.widget.CardView xmlns:card_view="http://schemas.android.com/apk/res-auto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginStart="@dimen/fragment_margin"
            android:layout_marginLeft="@dimen/fragment_margin"
            android:layout_marginTop="@dimen/fragment_margin"
            android:layout_marginEnd="@dimen/fragment_margin"
            android:layout_marginRight="@dimen/fragment_margin"
            card_view:cardBackgroundColor="@color/card_background"
            card_view:cardElevation="@dimen/card_elevation">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <software.cneuro.neurogertheme.TextViewFont
                    style="@style/SubjectCardTitleWhiteTextStyle.CustomPadding"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@color/primary"
                    android:gravity="center_vertical"
                    android:text="@string/sb_card_label_title_0"
                    app:myFont="Roboto-Thin_3.ttf" />

                <RadioGroup
                    android:id="@+id/subject_radiogroup_0_card_1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/fragment_margin"
                    android:layout_marginBottom="@dimen/fragment_margin"
                    android:gravity="center_vertical"
                    android:orientation="vertical">

                    <software.cneuro.neurogertheme.RadioButtonFont
                        style="@style/RadioButtonInputStyle"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/input_control_height"
                        android:text="@string/rdb_good"
                        app:myFont="Roboto-Light_3.ttf" />

                    <software.cneuro.neurogertheme.RadioButtonFont
                        style="@style/RadioButtonInputStyle"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/input_control_height"
                        android:text="@string/rdb_regular"
                        app:myFont="Roboto-Light_3.ttf" />

                    <software.cneuro.neurogertheme.RadioButtonFont
                        style="@style/RadioButtonInputStyle"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/input_control_height"
                        android:text="@string/rdb_bad"
                        app:myFont="Roboto-Light_3.ttf" />
                </RadioGroup>

            </LinearLayout>
        </androidx.v7.widget.CardView>

        <androidx.v7.widget.CardView xmlns:card_view="http://schemas.android.com/apk/res-auto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginStart="@dimen/fragment_margin"
            android:layout_marginLeft="@dimen/fragment_margin"
            android:layout_marginTop="@dimen/fragment_margin"
            android:layout_marginEnd="@dimen/fragment_margin"
            android:layout_marginRight="@dimen/fragment_margin"
            card_view:cardBackgroundColor="@color/card_background"
            card_view:cardElevation="@dimen/card_elevation">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <software.cneuro.neurogertheme.TextViewFont
                    style="@style/SubjectCardTitleWhiteTextStyle.CustomPadding"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@color/primary"
                    android:gravity="center_vertical"
                    android:text="@string/sb_card_label_title_1"
                    app:myFont="Roboto-Thin_3.ttf" />

                <RadioGroup
                    android:id="@+id/subject_radiogroup_1_card_1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/fragment_margin"
                    android:layout_marginBottom="@dimen/fragment_margin"
                    android:gravity="center_vertical"
                    android:orientation="vertical">

                    <software.cneuro.neurogertheme.RadioButtonFont
                        style="@style/RadioButtonInputStyle"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/input_control_height"
                        android:text="@string/rdb_excellent"
                        app:myFont="Roboto-Light_3.ttf" />

                    <software.cneuro.neurogertheme.RadioButtonFont
                        style="@style/RadioButtonInputStyle"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/input_control_height"
                        android:text="@string/rdb_very_good"
                        app:myFont="Roboto-Light_3.ttf" />

                    <software.cneuro.neurogertheme.RadioButtonFont
                        style="@style/RadioButtonInputStyle"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/input_control_height"
                        android:text="@string/rdb_good"
                        app:myFont="Roboto-Light_3.ttf" />

                    <software.cneuro.neurogertheme.RadioButtonFont
                        android:id="@+id/rb_regular"
                        style="@style/RadioButtonInputStyle"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/input_control_height"
                        android:text="@string/rdb_regular"
                        app:myFont="Roboto-Light_3.ttf" />

                    <software.cneuro.neurogertheme.RadioButtonFont
                        android:id="@+id/rb_bad"
                        style="@style/RadioButtonInputStyle"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/input_control_height"
                        android:text="@string/rdb_bad"
                        app:myFont="Roboto-Light_3.ttf" />
                </RadioGroup>

            </LinearLayout>
        </androidx.v7.widget.CardView>

        <androidx.v7.widget.CardView xmlns:card_view="http://schemas.android.com/apk/res-auto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginStart="@dimen/fragment_margin"
            android:layout_marginLeft="@dimen/fragment_margin"
            android:layout_marginTop="@dimen/fragment_margin"
            android:layout_marginEnd="@dimen/fragment_margin"
            android:layout_marginRight="@dimen/fragment_margin"
            card_view:cardBackgroundColor="@color/card_background"
            card_view:cardElevation="@dimen/card_elevation">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <software.cneuro.neurogertheme.TextViewFont
                    android:id="@+id/card_card_subtitle_2"
                    style="@style/SubjectCardTitleWhiteTextStyle.CustomPadding"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@color/primary"
                    android:gravity="center_vertical"
                    android:text="@string/sb_card_label_subtitle_2"
                    app:myFont="Roboto-Thin_3.ttf" />

                <RadioGroup
                    android:id="@+id/subject_radiogroup_2_card_1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/fragment_margin"
                    android:layout_marginBottom="@dimen/fragment_margin"
                    android:gravity="center_vertical"
                    android:orientation="vertical">

                    <software.cneuro.neurogertheme.RadioButtonFont
                        style="@style/RadioButtonInputStyle"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/input_control_height"
                        android:text="@string/rdb_better_than_before"
                        app:myFont="Roboto-Light_3.ttf" />

                    <software.cneuro.neurogertheme.RadioButtonFont
                        style="@style/RadioButtonInputStyle"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/input_control_height"
                        android:text="@string/rdb_same_as_before"
                        app:myFont="Roboto-Light_3.ttf" />

                    <software.cneuro.neurogertheme.RadioButtonFont
                        android:id="@+id/rb_worst_than_before"
                        style="@style/RadioButtonInputStyle"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/input_control_height"
                        android:text="@string/rdb_worst_as_before"
                        app:myFont="Roboto-Light_3.ttf" />
                </RadioGroup>


            </LinearLayout>
        </androidx.v7.widget.CardView>

        <androidx.v7.widget.CardView xmlns:card_view="http://schemas.android.com/apk/res-auto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginStart="@dimen/fragment_margin"
            android:layout_marginLeft="@dimen/fragment_margin"
            android:layout_marginTop="@dimen/fragment_margin"
            android:layout_marginEnd="@dimen/fragment_margin"
            android:layout_marginRight="@dimen/fragment_margin"
            android:layout_marginBottom="@dimen/fragment_margin"
            card_view:cardBackgroundColor="@color/card_background"
            card_view:cardElevation="@dimen/card_elevation">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingBottom="@dimen/fragment_margin">

                <software.cneuro.neurogertheme.TextViewFont
                    style="@style/SubjectCardTitleWhiteTextStyle.CustomPadding"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@color/primary"
                    android:gravity="center_vertical"
                    android:text="@string/sb_card_label_title_2"
                    app:myFont="Roboto-Thin_3.ttf" />

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/fragment_margin">

                    <ImageButton
                        android:id="@+id/card_2_help_icon_1"
                        style="@style/HelpIconRedStyle"
                        android:layout_width="@dimen/card_evaluation_help_image_height"
                        android:layout_height="@dimen/card_evaluation_help_image_height"
                        android:layout_alignParentEnd="true"
                        android:layout_alignParentRight="true"
                        android:layout_centerVertical="true"
                        android:contentDescription="@string/cd_list_item_icon" />

                    <software.cneuro.neurogertheme.CheckBoxFont
                        android:id="@+id/card_2_cbx_1"
                        style="@style/CheckboxStyle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_alignParentStart="true"
                        android:layout_alignParentLeft="true"
                        android:layout_marginEnd="@dimen/rdb_input_margin_right"
                        android:layout_marginRight="@dimen/rdb_input_margin_right"
                        android:layout_toStartOf="@id/card_2_help_icon_1"
                        android:layout_toLeftOf="@id/card_2_help_icon_1"
                        android:text="@string/cbx_1"
                        app:myFont="Roboto-Light_3.ttf" />
                </RelativeLayout>

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="8dp">

                    <ImageButton
                        android:id="@+id/card_2_help_icon_2"
                        style="@style/HelpIconRedStyle"
                        android:layout_width="@dimen/card_evaluation_help_image_height"
                        android:layout_height="@dimen/card_evaluation_help_image_height"
                        android:layout_alignParentEnd="true"
                        android:layout_alignParentRight="true"
                        android:layout_centerVertical="true"
                        android:contentDescription="@string/cd_list_item_icon" />

                    <software.cneuro.neurogertheme.CheckBoxFont
                        android:id="@+id/card_2_cbx_2"
                        style="@style/CheckboxStyle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_alignParentStart="true"
                        android:layout_alignParentLeft="true"
                        android:layout_alignParentTop="true"
                        android:layout_toStartOf="@id/card_2_help_icon_2"
                        android:layout_toLeftOf="@id/card_2_help_icon_2"
                        android:text="@string/cbx_2"
                        app:myFont="Roboto-Light_3.ttf" />
                </RelativeLayout>

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp">

                    <ImageButton
                        android:id="@+id/card_2_help_icon_3"
                        style="@style/HelpIconRedStyle"
                        android:layout_width="@dimen/card_evaluation_help_image_height"
                        android:layout_height="@dimen/card_evaluation_help_image_height"
                        android:layout_alignParentEnd="true"
                        android:layout_alignParentRight="true"
                        android:layout_centerVertical="true"
                        android:contentDescription="@string/cd_list_item_icon" />

                    <software.cneuro.neurogertheme.CheckBoxFont
                        android:id="@+id/card_2_cbx_3"
                        style="@style/CheckboxStyle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentStart="true"
                        android:layout_alignParentLeft="true"
                        android:layout_marginEnd="@dimen/rdb_input_margin_right"
                        android:layout_marginRight="@dimen/rdb_input_margin_right"
                        android:layout_toStartOf="@id/card_2_help_icon_3"
                        android:layout_toLeftOf="@id/card_2_help_icon_3"
                        android:text="@string/cbx_4"
                        app:myFont="Roboto-Light_3.ttf" />
                </RelativeLayout>

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <ImageButton
                        android:id="@+id/card_2_help_icon_4"
                        style="@style/HelpIconRedStyle"
                        android:layout_width="@dimen/card_evaluation_help_image_height"
                        android:layout_height="@dimen/card_evaluation_help_image_height"
                        android:layout_alignParentEnd="true"
                        android:layout_alignParentRight="true"
                        android:layout_centerVertical="true"
                        android:contentDescription="@string/cd_list_item_icon" />

                    <software.cneuro.neurogertheme.CheckBoxFont
                        android:id="@+id/card_2_cbx_4"
                        style="@style/CheckboxStyle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentStart="true"
                        android:layout_alignParentLeft="true"
                        android:layout_marginEnd="@dimen/rdb_input_margin_right"
                        android:layout_marginRight="@dimen/rdb_input_margin_right"
                        android:layout_toStartOf="@id/card_2_help_icon_4"
                        android:layout_toLeftOf="@id/card_2_help_icon_4"
                        android:text="@string/cbx_5"
                        app:myFont="Roboto-Light_3.ttf" />
                </RelativeLayout>

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <ImageButton
                        android:id="@+id/card_2_help_icon_5"
                        style="@style/HelpIconRedStyle"
                        android:layout_width="@dimen/card_evaluation_help_image_height"
                        android:layout_height="@dimen/card_evaluation_help_image_height"
                        android:layout_alignParentEnd="true"
                        android:layout_alignParentRight="true"
                        android:layout_centerVertical="true"
                        android:contentDescription="@string/cd_list_item_icon" />

                    <software.cneuro.neurogertheme.CheckBoxFont
                        android:id="@+id/card_2_cbx_5"
                        style="@style/CheckboxStyle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentStart="true"
                        android:layout_alignParentLeft="true"
                        android:layout_marginEnd="@dimen/rdb_input_margin_right"
                        android:layout_marginRight="@dimen/rdb_input_margin_right"
                        android:layout_toStartOf="@id/card_2_help_icon_5"
                        android:layout_toLeftOf="@id/card_2_help_icon_5"
                        android:text="@string/cbx_6"
                        app:myFont="Roboto-Light_3.ttf" />
                </RelativeLayout>

                <software.cneuro.neurogertheme.CheckBoxFont
                    android:id="@+id/card_2_cbx_6"
                    style="@style/CheckboxStyle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="@dimen/rdb_input_margin_right"
                    android:layout_marginRight="@dimen/rdb_input_margin_right"
                    android:text="@string/cbx_7"
                    app:myFont="Roboto-Light_3.ttf" />

                <software.cneuro.neurogertheme.CheckBoxFont
                    android:id="@+id/card_2_cbx_7"
                    style="@style/CheckboxStyle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="@dimen/rdb_input_margin_right"
                    android:layout_marginRight="@dimen/rdb_input_margin_right"
                    android:text="@string/cbx_8"
                    app:myFont="Roboto-Light_3.ttf" />

            </LinearLayout>
        </androidx.v7.widget.CardView>

        <include layout="@layout/action_btn_container" />

    </LinearLayout>

</ScrollView>
