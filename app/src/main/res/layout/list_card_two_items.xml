<?xml version="1.0" encoding="utf-8"?>
<androidx.v7.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_gravity="center"
    android:layout_marginLeft="@dimen/fragment_margin"
    android:layout_marginTop="@dimen/fragment_margin"
    android:layout_marginRight="@dimen/fragment_margin"
    app:cardBackgroundColor="@color/card_background"
    app:cardElevation="@dimen/card_elevation">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <software.cneuro.neurogertheme.TextViewFont
            android:id="@+id/card_title"
            style="@style/SubjectCardTitleWhiteTextStyle.CustomPadding"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            app:myFont="Roboto-Thin_3.ttf"
            tools:text="@string/list_item_text" />

        <software.cneuro.neurogertheme.TextViewFont
            android:id="@+id/card_text"
            style="@style/EvaluationCardDetailTextStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/fragment_margin"
            android:layout_marginBottom="@dimen/fragment_margin"
            android:paddingLeft="@dimen/fragment_margin"
            android:paddingEnd="@dimen/fragment_margin"
            android:paddingRight="@dimen/fragment_margin"
            app:myFont="Roboto-Light_3.ttf"
            tools:text="@string/list_item_sub_text" />

    </LinearLayout>

</androidx.v7.widget.CardView>