<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    android:id="@+id/main_container"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:padding="16dp"
    tools:context=".LicenseActivity">

    <ImageView
        android:id="@+id/iv_logo"
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:src="@drawable/neuronic_logo"
        app:layout_constraintHeight_max="80dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@+id/tv_title"
        app:layout_constraintVertical_chainStyle="spread_inside" />

    <TextView
        android:id="@+id/tv_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="sans-serif-black"
        android:letterSpacing="0.05"
        android:text="@string/tv_title_main"
        android:textColor="#000000"
        android:textSize="20sp"
        app:layout_constraintTop_toBottomOf="@id/iv_logo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@+id/layout_username" />

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/layout_username"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/username_hint"
        app:boxStrokeColor="#000000"
        app:hintTextColor="#000000"
        app:layout_constraintTop_toBottomOf="@id/tv_title"
        app:layout_constraintBottom_toTopOf="@+id/layout_password">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/et_username"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#000000" />
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/layout_password"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/password_hint"
        app:boxStrokeColor="#000000"
        app:endIconMode="password_toggle"
        app:endIconTint="#000000"
        app:hintTextColor="#000000"
        app:layout_constraintTop_toBottomOf="@id/layout_username"
        app:layout_constraintBottom_toTopOf="@+id/ll_buttons_top">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/et_password"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textPassword"
            android:textColor="#000000" />
    </com.google.android.material.textfield.TextInputLayout>

    <LinearLayout
        android:id="@+id/ll_buttons_top"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintTop_toBottomOf="@id/layout_password"
        app:layout_constraintBottom_toTopOf="@+id/card_status">

        <Button
            android:id="@+id/btn_save_neu"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/btn_export_huella"
            android:textAllCaps="false"
            android:textColor="#000000"
            app:strokeColor="#000000" />

        <View android:layout_width="8dp" android:layout_height="0dp" />

        <Button
            android:id="@+id/btn_load_neu"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/btn_cargar_neu"
            android:textAllCaps="false"
            android:textColor="#000000"
            app:strokeColor="#000000" />
    </LinearLayout>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_status"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintHeight_min="80dp"
        app:layout_constraintHeight_percent="0.15"
        app:cardBackgroundColor="#F1F5F9"
        app:cardCornerRadius="8dp"
        app:strokeColor="#000000"
        app:strokeWidth="1dp"
        app:layout_constraintTop_toBottomOf="@id/ll_buttons_top"
        app:layout_constraintBottom_toTopOf="@+id/layout_license_code">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-bold"
                android:text="@string/status_box_label"
                android:textColor="#334155"
                android:textSize="10sp" />

            <TextView
                android:id="@+id/tv_info_box"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:fontFamily="monospace"
                android:text="Cargando información..."
                android:textColor="#000000"
                android:textSize="11sp" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/layout_license_code"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:hint="@string/license_code_hint"
        app:boxStrokeColor="#000000"
        app:hintTextColor="#000000"
        app:layout_constraintHeight_percent="0.12"
        app:layout_constraintTop_toBottomOf="@id/card_status"
        app:layout_constraintBottom_toTopOf="@+id/btn_validate">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/et_license_code"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="top"
            android:inputType="textMultiLine"
            android:textColor="#000000"
            android:textSize="12sp" />
    </com.google.android.material.textfield.TextInputLayout>

    <Button
        android:id="@+id/btn_validate"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:backgroundTint="#000000"
        android:text="@string/btn_validar_init"
        android:textColor="#FFFFFF"
        android:minHeight="48dp"
        app:layout_constraintTop_toBottomOf="@id/layout_license_code"
        app:layout_constraintBottom_toTopOf="@+id/btn_open_app" />

    <Button
        android:id="@+id/btn_open_app"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:backgroundTint="#059669"
        android:enabled="false"
        android:text="@string/btn_entrar_app"
        android:minHeight="48dp"
        app:layout_constraintTop_toBottomOf="@id/btn_validate"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>