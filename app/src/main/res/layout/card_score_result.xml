<?xml version="1.0" encoding="utf-8"?>
<androidx.v7.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_gravity="center"
    app:cardBackgroundColor="@color/card_background"
    app:cardCornerRadius="@dimen/card_corner_radius"
    app:cardElevation="@dimen/card_elevation"
    app:contentPadding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <software.cneuro.neurogertheme.TextViewFont
            android:id="@+id/card_result"
            style="@style/SubjectCardTitleBlackTextStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="@dimen/fragment_margin_14"
            android:paddingLeft="@dimen/fragment_margin_14"
            android:paddingEnd="@dimen/fragment_margin"
            android:paddingRight="@dimen/fragment_margin"
            android:paddingBottom="@dimen/fragment_margin_14"
            android:text="@string/result_ok"
            app:myFont="Roboto-Light_3.ttf" />

        <software.cneuro.neurogertheme.TextViewFont
            android:id="@+id/card_score"
            style="@style/EvaluationCardDetailTextStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="@dimen/fragment_margin_14"
            android:paddingLeft="@dimen/fragment_margin_14"
            android:paddingEnd="@dimen/fragment_margin"
            android:paddingRight="@dimen/fragment_margin"
            android:text="@string/card_label_score"
            app:myFont="Roboto-Light_3.ttf" />

    </LinearLayout>

</androidx.v7.widget.CardView>