<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:card_view="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <androidx.v7.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginLeft="@dimen/fragment_margin"
            android:layout_marginTop="@dimen/fragment_margin"
            android:layout_marginRight="@dimen/fragment_margin"
            app:cardBackgroundColor="@color/card_background"
            app:cardCornerRadius="@dimen/card_corner_radius"
            app:cardElevation="@dimen/card_elevation"
            app:contentPadding="16dp">

            <software.cneuro.neurogertheme.TextViewFont
                android:id="@+id/card_result"
                style="@style/SubjectCardTitleBlackTextStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/result_ok"
                app:myFont="Roboto-Light_3.ttf" />
        </androidx.v7.widget.CardView>

        <androidx.v7.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginStart="@dimen/fragment_margin"
            android:layout_marginLeft="@dimen/fragment_margin"
            android:layout_marginTop="@dimen/fragment_margin"
            android:layout_marginEnd="@dimen/fragment_margin"
            android:layout_marginRight="@dimen/fragment_margin"
            card_view:cardBackgroundColor="@color/card_background"
            card_view:cardCornerRadius="@dimen/card_corner_radius"
            card_view:cardElevation="@dimen/card_elevation">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingBottom="@dimen/fragment_margin">

                <software.cneuro.neurogertheme.TextViewFont
                    style="@style/SubjectCardTitleWhiteTextStyle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@color/primary"
                    android:gravity="center_vertical"
                    android:padding="@dimen/fragment_margin"
                    android:text="@string/sb_card_label_title_0"
                    app:myFont="Roboto-Thin_3.ttf" />

                <software.cneuro.neurogertheme.TextViewFont
                    android:id="@+id/card_1_answer_0"
                    style="@style/EvaluationCardDetailTextStyle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/fragment_margin"
                    android:paddingLeft="@dimen/fragment_margin"
                    android:paddingEnd="@dimen/fragment_margin"
                    android:paddingRight="@dimen/fragment_margin"
                    app:myFont="Roboto-Light_3.ttf"
                    tools:text="@string/label_answer" />

            </LinearLayout>
        </androidx.v7.widget.CardView>

        <androidx.v7.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginStart="@dimen/fragment_margin"
            android:layout_marginLeft="@dimen/fragment_margin"
            android:layout_marginTop="@dimen/fragment_margin"
            android:layout_marginEnd="@dimen/fragment_margin"
            android:layout_marginRight="@dimen/fragment_margin"
            card_view:cardBackgroundColor="@color/card_background"
            card_view:cardCornerRadius="@dimen/card_corner_radius"
            card_view:cardElevation="@dimen/card_elevation">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingBottom="@dimen/fragment_margin">

                <software.cneuro.neurogertheme.TextViewFont
                    style="@style/SubjectCardTitleWhiteTextStyle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@color/primary"
                    android:gravity="center_vertical"
                    android:padding="@dimen/fragment_margin"
                    android:text="@string/sb_card_label_title_1"
                    app:myFont="Roboto-Thin_3.ttf" />

                <software.cneuro.neurogertheme.TextViewFont
                    android:id="@+id/card_1_answer_1"
                    style="@style/EvaluationCardDetailTextStyle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/fragment_margin"
                    android:paddingLeft="@dimen/fragment_margin"
                    android:paddingEnd="@dimen/fragment_margin"
                    android:paddingRight="@dimen/fragment_margin"
                    app:myFont="Roboto-Light_3.ttf"
                    tools:text="@string/label_answer" />

            </LinearLayout>
        </androidx.v7.widget.CardView>

        <androidx.v7.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginStart="@dimen/fragment_margin"
            android:layout_marginLeft="@dimen/fragment_margin"
            android:layout_marginTop="@dimen/fragment_margin"
            android:layout_marginEnd="@dimen/fragment_margin"
            android:layout_marginRight="@dimen/fragment_margin"
            card_view:cardBackgroundColor="@color/card_background"
            card_view:cardCornerRadius="@dimen/card_corner_radius"
            card_view:cardElevation="@dimen/card_elevation">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingBottom="@dimen/fragment_margin">

                <software.cneuro.neurogertheme.TextViewFont
                    android:id="@+id/card_card_subtitle_2"
                    style="@style/SubjectCardTitleWhiteTextStyle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@color/primary"
                    android:gravity="center_vertical"
                    android:padding="@dimen/fragment_margin"
                    android:text="@string/sb_card_label_subtitle_2"
                    app:myFont="Roboto-Thin_3.ttf" />

                <software.cneuro.neurogertheme.TextViewFont
                    android:id="@+id/card_1_answer_2"
                    style="@style/EvaluationCardDetailTextStyle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/fragment_margin"
                    android:paddingLeft="@dimen/fragment_margin"
                    android:paddingEnd="@dimen/fragment_margin"
                    android:paddingRight="@dimen/fragment_margin"
                    app:myFont="Roboto-Light_3.ttf"
                    tools:text="@string/label_answer" />


            </LinearLayout>
        </androidx.v7.widget.CardView>


        <androidx.v7.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginStart="@dimen/fragment_margin"
            android:layout_marginLeft="@dimen/fragment_margin"
            android:layout_marginTop="@dimen/fragment_margin"
            android:layout_marginEnd="@dimen/fragment_margin"
            android:layout_marginRight="@dimen/fragment_margin"
            card_view:cardBackgroundColor="@color/card_background"
            card_view:cardCornerRadius="@dimen/card_corner_radius"
            card_view:cardElevation="@dimen/card_elevation">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingBottom="@dimen/fragment_margin">

                <software.cneuro.neurogertheme.TextViewFont
                    style="@style/SubjectCardTitleWhiteTextStyle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@color/primary"
                    android:gravity="center_vertical"
                    android:padding="@dimen/fragment_margin"
                    android:text="@string/sb_card_label_title_2"
                    app:myFont="Roboto-Thin_3.ttf" />

                <LinearLayout
                    android:id="@+id/card_2_answer_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />

            </LinearLayout>
        </androidx.v7.widget.CardView>

        <androidx.v7.widget.CardView
            android:id="@+id/card_3_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_margin="@dimen/fragment_margin"
            card_view:cardBackgroundColor="@color/card_background"
            card_view:cardCornerRadius="@dimen/card_corner_radius"
            android:visibility="gone"
            card_view:cardElevation="@dimen/card_elevation">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingBottom="@dimen/fragment_margin">

                <software.cneuro.neurogertheme.TextViewFont
                    android:id="@+id/card_3_title"
                    style="@style/SubjectCardTitleWhiteTextStyle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@color/primary"
                    android:gravity="center_vertical"
                    android:padding="@dimen/fragment_margin"
                    android:text="@string/sb_card_label_title_3"
                    app:myFont="Roboto-Thin_3.ttf" />

                <software.cneuro.neurogertheme.TextViewFont
                    android:id="@+id/card_3_answer_1"
                    style="@style/EvaluationCardDetailTextStyle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/fragment_margin"
                    android:paddingLeft="@dimen/fragment_margin"
                    android:paddingEnd="@dimen/fragment_margin"
                    android:paddingRight="@dimen/fragment_margin"
                    android:text="@string/label_answer"
                    app:myFont="Roboto-Light_3.ttf" />

            </LinearLayout>
        </androidx.v7.widget.CardView>

        <androidx.v7.widget.CardView
            android:id="@+id/card_4_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_margin="@dimen/fragment_margin"
            android:visibility="gone"
            card_view:cardBackgroundColor="@color/card_background"
            card_view:cardCornerRadius="@dimen/card_corner_radius"
            card_view:cardElevation="@dimen/card_elevation">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingBottom="@dimen/fragment_margin">

                <software.cneuro.neurogertheme.TextViewFont
                    android:id="@+id/card_4_title"
                    style="@style/SubjectCardTitleWhiteTextStyle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@color/primary"
                    android:gravity="center_vertical"
                    android:padding="@dimen/fragment_margin"
                    android:text="@string/sb_card_label_title_4"
                    app:myFont="Roboto-Thin_3.ttf" />

                <software.cneuro.neurogertheme.TextViewFont
                    android:id="@+id/card_4_answer_1"
                    style="@style/EvaluationCardDetailTextStyle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/fragment_margin"
                    android:paddingLeft="@dimen/fragment_margin"
                    android:paddingEnd="@dimen/fragment_margin"
                    android:paddingRight="@dimen/fragment_margin"
                    android:text="@string/label_answer"
                    app:myFont="Roboto-Light_3.ttf" />

            </LinearLayout>
        </androidx.v7.widget.CardView>

        <androidx.v7.widget.CardView
            android:id="@+id/card_5_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_margin="@dimen/fragment_margin"
            android:visibility="gone"
            card_view:cardBackgroundColor="@color/card_background"
            card_view:cardCornerRadius="@dimen/card_corner_radius"
            card_view:cardElevation="@dimen/card_elevation">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <software.cneuro.neurogertheme.TextViewFont
                    style="@style/SubjectCardTitleWhiteTextStyle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@color/primary"
                    android:gravity="center_vertical"
                    android:padding="@dimen/fragment_margin"
                    android:text="@string/sb_card_label_title_5"
                    app:myFont="Roboto-Thin_3.ttf" />

                <software.cneuro.neurogertheme.TextViewFont
                    android:id="@+id/card_5_answer_1"
                    style="@style/EvaluationCardDetailTextStyle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/fragment_margin"
                    android:layout_marginBottom="@dimen/fragment_margin"
                    android:paddingLeft="@dimen/fragment_margin"
                    android:paddingEnd="@dimen/fragment_margin"
                    android:paddingRight="@dimen/fragment_margin"
                    android:text="@string/label_answer"
                    app:myFont="Roboto-Light_3.ttf" />

            </LinearLayout>
        </androidx.v7.widget.CardView>

    </LinearLayout>

</ScrollView>
