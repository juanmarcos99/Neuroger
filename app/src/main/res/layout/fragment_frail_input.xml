<?xml version="1.0" encoding="utf-8"?>
<androidx.v4.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <androidx.v7.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginLeft="@dimen/fragment_margin"
            android:layout_marginTop="@dimen/fragment_margin"
            android:layout_marginRight="@dimen/fragment_margin"
            app:cardBackgroundColor="@color/card_background"
            app:cardElevation="@dimen/card_elevation">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <software.cneuro.neurogertheme.TextViewFont
                    style="@style/SubjectCardTitleWhiteTextStyle.CustomPadding"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@color/primary"
                    android:gravity="center_vertical"
                    android:text="@string/card_label_fatigue"
                    app:myFont="Roboto-Thin_3.ttf" />

                <RadioGroup
                    android:id="@+id/detail_card_1_rg"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="16dp"
                    android:orientation="vertical" />
            </LinearLayout>
        </androidx.v7.widget.CardView>

        <androidx.v7.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginLeft="@dimen/fragment_margin"
            android:layout_marginTop="@dimen/fragment_margin"
            android:layout_marginRight="@dimen/fragment_margin"
            app:cardBackgroundColor="@color/card_background"
            app:cardElevation="@dimen/card_elevation">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <software.cneuro.neurogertheme.TextViewFont
                    style="@style/SubjectCardTitleWhiteTextStyle.CustomPadding"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@color/primary"
                    android:gravity="center_vertical"
                    android:text="@string/card_label_resistance"
                    app:myFont="Roboto-Thin_3.ttf" />

                <RadioGroup
                    android:id="@+id/detail_card_2_rg"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="16dp"
                    android:orientation="vertical" />
            </LinearLayout>
        </androidx.v7.widget.CardView>

        <androidx.v7.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginLeft="@dimen/fragment_margin"
            android:layout_marginTop="@dimen/fragment_margin"
            android:layout_marginRight="@dimen/fragment_margin"
            app:cardBackgroundColor="@color/card_background"
            app:cardElevation="@dimen/card_elevation">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <software.cneuro.neurogertheme.TextViewFont
                    style="@style/SubjectCardTitleWhiteTextStyle.CustomPadding"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@color/primary"
                    android:gravity="center_vertical"
                    android:text="@string/card_label_wandering"
                    app:myFont="Roboto-Thin_3.ttf" />

                <RadioGroup
                    android:id="@+id/detail_card_3_rg"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="16dp"
                    android:orientation="vertical" />
            </LinearLayout>
        </androidx.v7.widget.CardView>

        <androidx.v7.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginLeft="@dimen/fragment_margin"
            android:layout_marginTop="@dimen/fragment_margin"
            android:layout_marginRight="@dimen/fragment_margin"
            app:cardBackgroundColor="@color/card_background"
            app:cardElevation="@dimen/card_elevation">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <software.cneuro.neurogertheme.TextViewFont
                    style="@style/SubjectCardTitleWhiteTextStyle.CustomPadding"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@color/primary"
                    android:gravity="center_vertical"
                    android:text="@string/card_label_diseases"
                    app:myFont="Roboto-Thin_3.ttf" />

                <LinearLayout
                    android:id="@+id/detail_card_4_layout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="16dp"
                    android:orientation="vertical" />
            </LinearLayout>
        </androidx.v7.widget.CardView>

        <androidx.v7.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_margin="@dimen/fragment_margin"
            app:cardBackgroundColor="@color/card_background"
            app:cardElevation="@dimen/card_elevation">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <software.cneuro.neurogertheme.TextViewFont
                    style="@style/SubjectCardTitleWhiteTextStyle.CustomPadding"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@color/primary"
                    android:gravity="center_vertical"
                    android:text="@string/card_label_weight_loss"
                    app:myFont="Roboto-Thin_3.ttf" />

                <software.cneuro.neurogertheme.TextViewFont
                    style="@style/SubjectCardTitleBlackTextStyle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:padding="@dimen/fragment_margin"
                    android:text="@string/edittext_weight_loss_current_hint"
                    app:myFont="Roboto-Thin_3.ttf" />

                <software.cneuro.neurogertheme.EditTextFont
                    android:id="@+id/edit_weight_loss_current"
                    style="@style/EditTextStyle"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/input_control_height"
                    android:layout_marginStart="@dimen/fragment_margin"
                    android:layout_marginLeft="@dimen/fragment_margin"
                    android:layout_marginEnd="@dimen/fragment_margin"
                    android:layout_marginRight="@dimen/fragment_margin"
                    android:inputType="number"
                    app:myFont="Roboto-Light_3.ttf" />

                <software.cneuro.neurogertheme.TextViewFont
                    style="@style/SubjectCardTitleBlackTextStyle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:padding="@dimen/fragment_margin"
                    android:text="@string/edittext_weight_loss_1_year_ago_hint"
                    app:myFont="Roboto-Thin_3.ttf" />

                <software.cneuro.neurogertheme.EditTextFont
                    android:id="@+id/edit_weight_loss_1_year_ago"
                    style="@style/EditTextStyle"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/input_control_height"
                    android:layout_marginStart="@dimen/fragment_margin"
                    android:layout_marginLeft="@dimen/fragment_margin"
                    android:layout_marginEnd="@dimen/fragment_margin"
                    android:layout_marginRight="@dimen/fragment_margin"
                    android:inputType="number"
                    app:myFont="Roboto-Light_3.ttf" />

                <software.cneuro.neurogertheme.TextViewFont
                    style="@style/SubjectCardTitleBlackTextStyle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:padding="@dimen/fragment_margin"
                    android:text="@string/how_much_weight"
                    app:myFont="Roboto-Thin_3.ttf" />
            </LinearLayout>
        </androidx.v7.widget.CardView>

        <include layout="@layout/action_btn_container" />
    </LinearLayout>
</androidx.v4.widget.NestedScrollView>