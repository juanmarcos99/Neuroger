<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Border gray -->
    <item>
        <shape android:shape="rectangle">
            <solid
                android:width="1dip"
                android:color="@color/edittext_border" />

            <padding
                android:bottom="1dip"
                android:left="1dip"
                android:right="1dip"
                android:top="1dip" />
        </shape>
    </item>

    <!-- Background -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/edittext_normal" />
        </shape>
    </item>

</layer-list>