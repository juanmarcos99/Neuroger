<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android" >

    <!-- White border -->
    <item>
        <shape android:shape="rectangle" >
            <solid
                android:width="1dip"
                android:color="#ffffff" />

            <padding
                android:bottom="1dip"
                android:left="1dip"
                android:right="1dip"
                android:top="1dip" />

            <corners android:radius="5dip" />
        </shape>
    </item>

    <!-- Background -->
    <item>
        <shape android:shape="rectangle" >
            <solid
                android:color="@color/primary" />

            <corners android:radius="5dip" />
        </shape>
    </item>

</layer-list>